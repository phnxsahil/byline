# Copy this to .env and fill in your values.
# Never commit .env to git.

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://dispatch:dispatch@localhost:5432/dispatch

# ── LLM providers ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...        # Generation and critique (LangGraph nodes)
OPENAI_API_KEY=sk-...               # Embeddings only (text-embedding-3-small)

# ── Composio (Phase 3 — leave blank until then) ───────────────────────────────
COMPOSIO_API_KEY=

# ── App ───────────────────────────────────────────────────────────────────────
# A single secret for the simple one-user session. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
APP_SECRET=
NEXT_PUBLIC_API_URL=http://localhost:8000
